rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ==================== HELPERS ====================
    function isAuthenticated() {
      return request.auth != null;
    }

    function userId() {
      return request.auth.uid;
    }

    function userRole() {
      return request.auth.token.role;
    }

    function isAdmin() {
      return isAuthenticated() && userRole() == 'admin';
    }

    function isProducer() {
      return isAuthenticated() && userRole() == 'produtor';
    }

    function isDriver() {
      return isAuthenticated() && userRole() == 'entregador';
    }

    // Verifica se o usuário autenticado é dono do perfil de produtor
    function isOwnerOfProdutor(produtorId) {
      return isProducer() &&
             request.auth.token.produtorIds != null &&
             produtorId in request.auth.token.produtorIds;
    }

    function hasOnlyAllowedFields(allowedFields) {
      return request.resource.data.diff(resource.data)
              .affectedKeys()
              .hasOnly(allowedFields);
    }

    function isUnchanged(field) {
      return request.resource.data[field] == resource.data[field];
    }

    // ==================== USERS ====================
    match /users/{uid} {
      allow create: if isAuthenticated() && userId() == uid
                    && request.resource.data.role == 'cliente'
                    && request.resource.data.uid == uid;

      allow read: if userId() == uid || isAdmin();

      allow update: if (userId() == uid
                       && isUnchanged('role')
                       && isUnchanged('approved')
                       && isUnchanged('uid'))
                    || isAdmin();

      allow delete: if false;

      match /addresses/{addressId} {
        allow read, write: if userId() == uid;
      }

      match /fcmTokens/{tokenId} {
        allow read, write: if userId() == uid;
      }

      match /notifications/{notifId} {
        allow read: if userId() == uid;
        allow update: if userId() == uid && hasOnlyAllowedFields(['read']);
        allow create, delete: if false;
      }
    }

    // ==================== PRODUTORES (hortas) ====================
    match /produtores/{produtorId} {
      allow read: if resource.data.status == 'approved'
                  || isOwnerOfProdutor(produtorId)
                  || (isProducer() && resource.data.ownerUid == userId())
                  || isAdmin();

      // Qualquer usuário autenticado pode submeter um cadastro pendente.
      // O role 'produtor' só é setado APÓS aprovação pelo admin.
      allow create: if isAuthenticated()
                    && request.resource.data.ownerUid == userId()
                    && request.resource.data.status == 'pending';

      allow update: if (isOwnerOfProdutor(produtorId)
                       && isUnchanged('status')
                       && isUnchanged('commission')
                       && isUnchanged('approvedAt'))
                    || isAdmin();

      allow delete: if false;

      match /categories/{categoryId} {
        allow read: if true;
        allow write: if isOwnerOfProdutor(produtorId) || isAdmin();
      }

      match /products/{productId} {
        allow read: if true;
        allow write: if isOwnerOfProdutor(produtorId) || isAdmin();
      }

      match /stats/{date} {
        allow read: if isOwnerOfProdutor(produtorId) || isAdmin();
        allow write: if false;
      }
    }

    // ==================== ORDERS ====================
    match /orders/{orderId} {
      allow read: if (isAuthenticated() && resource.data.customerId == userId())
                  || (isProducer() && isOwnerOfProdutor(resource.data.produtorId))
                  || (isDriver() && (resource.data.deliveryDriverId == userId()
                      || resource.data.status == 'ready'))
                  || isAdmin();

      allow create: if false;

      allow update: if isAdmin()
                    || (isProducer()
                        && isOwnerOfProdutor(resource.data.produtorId)
                        && hasOnlyAllowedFields(['status', 'statusHistory',
                                                  'confirmedAt', 'preparingAt',
                                                  'readyAt', 'onDeliveryAt']))
                    || (isDriver()
                        && resource.data.deliveryDriverId == userId()
                        && hasOnlyAllowedFields(['status', 'statusHistory',
                                                  'driverLocation',
                                                  'driverLocationUpdatedAt',
                                                  'deliveredAt']))
                    || (isAuthenticated()
                        && resource.data.customerId == userId()
                        && resource.data.status in ['pending', 'confirmed']
                        && request.resource.data.status == 'cancelled'
                        && hasOnlyAllowedFields(['status', 'statusHistory']));

      allow delete: if false;
    }

    // ==================== HORTAS ====================
    match /hortas/{hortaId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==================== MP TOKENS ====================
    // Tokens MP dos produtores — somente Cloud Functions (admin SDK) acessam.
    match /mp_tokens/{produtorId} {
      allow read, write: if false;
    }

    // ==================== PEDIDOS FILHOS ====================
    match /pedidos_filhos/{filhoId} {
      allow read: if isAdmin()
                  || (isProducer() && isOwnerOfProdutor(resource.data.produtorId))
                  || (isAuthenticated() && resource.data.customerId == userId());

      allow create: if false;

      allow update: if isAdmin()
                    || (isProducer()
                        && isOwnerOfProdutor(resource.data.produtorId)
                        && hasOnlyAllowedFields(['status', 'updatedAt']));

      allow delete: if false;
    }

    // ==================== COUPONS ====================
    match /coupons/{couponCode} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ==================== DELIVERY DRIVERS ====================
    match /deliveryDrivers/{driverId} {
      // Qualquer usuário autenticado pode ler/criar seu próprio perfil de entregador
      allow read: if (isAuthenticated() && userId() == driverId) || isAdmin();

      allow create: if isAuthenticated()
                    && userId() == driverId
                    && request.resource.data.status == 'pending_approval';

      allow update: if (isDriver() && userId() == driverId
                       && isUnchanged('status')
                       && isUnchanged('approvedAt'))
                    || isAdmin();

      allow delete: if false;
    }

    // ==================== AUDIT LOGS ====================
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ==================== APP CONFIG ====================
    match /appConfig/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==================== DEFAULT DENY ====================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
